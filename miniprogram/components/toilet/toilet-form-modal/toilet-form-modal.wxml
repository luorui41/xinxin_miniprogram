<view class="modalContainer" wx:if="{{visible}}" bindtap="handleClose">
  <view class="modalContent" catchtap="preventBubble">
    <view class="modalHeader">
      <text class="modalTitle">{{mode === 'add' ? '新增如厕记录' : '编辑如厕记录'}}</text>
      <view class="closeBtn" bindtap="handleClose">
        <text class="closeIcon">×</text>
      </view>
    </view>

    <view class="modalBody">
      <!-- 时间选择 -->
      <view class="formItem">
        <view class="formLabel">时间</view>
        <picker mode="time" value="{{time}}" bindchange="handleTimeChange">
          <view class="pickerValue">{{time}}</view>
        </picker>
      </view>

      <!-- 软硬程度选择 -->
      <view class="formItem">
        <view class="formLabel">软硬程度</view>
        <picker mode="selector" range="{{hardnessOptions}}" range-key="label" value="{{hardness - 1}}" bindchange="handleHardnessChange">
          <view class="pickerValue">{{hardnessOptions[hardness - 1].label}}</view>
        </picker>
      </view>

      <!-- 如厕量程度选择 -->
      <view class="formItem">
        <view class="formLabel">如厕量</view>
        <picker mode="selector" range="{{amountOptions}}" range-key="label" value="{{amount - 1}}" bindchange="handleAmountChange">
          <view class="pickerValue">{{amountOptions[amount - 1].label}}</view>
        </picker>
      </view>

      <!-- 备注 -->
      <view class="formItem">
        <view class="formLabel">备注</view>
        <textarea class="textareaInput" value="{{desc}}" bindinput="handleDescInput" placeholder="请输入备注信息" maxlength="200"></textarea>
      </view>
    </view>

    <view class="modalFooter">
      <button class="deleteBtn" wx:if="{{mode === 'edit'}}" bindtap="handleDelete">删除</button>
      <button class="submitBtn" bindtap="handleSubmit" disabled="{{submitting}}">
        {{submitting ? '提交中...' : '提交'}}
      </button>
    </view>
  </view>
</view>
<view class="dietSummaryCard">
  <view class="dietSummaryHeader">
    <view class="dietSummaryHeaderLeft">
      <text class="dietSummaryTitle">本周饮食小结</text>
      <text class="dietSummarySubTitle">{{mondayStr}} ~ {{todayStr}}</text>
    </view>
    <view class="dietSummaryMore" bindtap="handleMore">
      <text class="dietSummaryMoreText">更多</text>
      <image src="/images/arrow-right.png" class="dietSummaryMoreArrow"/>
    </view>
  </view>
  <view wx:if="{{loading}}" class="dietSummaryLoading">
    <text>加载中...</text>
  </view>
  <view wx:elif="{{dietSummary.length === 0}}" class="dietSummaryEmpty">
    <text>暂无记录</text>
  </view>
  <view wx:else class="dietSummaryList">
    <block wx:for="{{dietSummary}}" wx:key="typeDesc">
      <view class="dietSummaryItem" bindtap="handleItemClick" data-item="{{item}}">
        <text class="dietSummaryType">{{item.typeDesc}}</text>
        <view class="dietSummaryRight">
          <text class="dietSummaryCount">{{item.recipeCount}}种 {{item.count}}次</text>
        </view>
      </view>
    </block>
  </view>
</view>

<!-- 使用 root-portal 渲染弹窗到页面根节点 -->
<root-portal>
  <view wx:if="{{recipeModalVisible}}" class="recipeModalMask" bindtap="handleCloseModal">
    <view class="recipeModalContent" catchtap="preventBubble">
      <view class="recipeModalHeader">
        <text class="recipeModalTitle">{{selectedType.typeDesc || ''}}</text>
        <view class="recipeModalClose" bindtap="handleCloseModal">×</view>
      </view>
      <view class="recipeModalBody">
        <view wx:if="{{!selectedType.recipes || selectedType.recipes.length === 0}}" class="recipeModalEmpty">
          <text>暂无菜谱记录</text>
        </view>
        <view wx:else class="recipeModalList">
          <block wx:for="{{selectedType.recipes}}" wx:key="recipeName">
            <view class="recipeModalItem">
              <text class="recipeModalRecipeName">{{item.recipeName}}</text>
              <text class="recipeModalCount">{{item.count}}次</text>
            </view>
          </block>
        </view>
      </view>
    </view>
  </view>
</root-portal>
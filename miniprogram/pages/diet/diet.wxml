<navigation-bar title="饮食" back="{{false}}" color="black" background="#FFF"></navigation-bar>
<week-navigator weekLabel="{{weekLabel}}" dateRange="{{dateRange}}" viewMode="{{viewMode}}" bind:prevWeek="handlePrevWeek" bind:nextWeek="handleNextWeek" bind:viewModeChange="handleViewModeChange"></week-navigator>

<scroll-view class="scrollarea" scroll-y type="list" refresher-enabled="{{true}}" refresher-triggered="{{refresherTriggered}}" bindrefresherrefresh="onRefresherRefresh">
  <view class="container">
    <!-- 加载中 -->
    <view wx:if="{{loading}}" class="loadingBox">
      <text class="loadingText">加载中...</text>
    </view>

    <!-- 七天列表 -->
    <view wx:if="{{!loading}}" class="daysList">
      <block wx:for="{{weekDays}}" wx:key="dateStr">
        <day-card dateStr="{{item.dateStr}}" dayRecord="{{weekRecords[item.dateStr]}}" mealTypes="{{mealTypes}}" bind:addMeal="handleAddMeal" bind:deleteMeal="handleDeleteMeal"></day-card>
      </block>
    </view>
  </view>
</scroll-view>

<diet-form-modal
  visible="{{formVisible}}"
  formDate="{{formDate}}"
  formMealType="{{formMealType}}"
  formDietDesc="{{formDietDesc}}"
  recipes="{{recipes}}"
  filteredRecipes="{{filteredRecipes}}"
  filterType="{{filterType}}"
  selectedRecipe="{{selectedRecipe}}"
  selectedRecipeIndex="{{selectedRecipeIndex}}"
  submitting="{{submitting}}"
  loadingRecipes="{{loadingRecipes}}"
  mealOptions="{{mealOptions}}"
  recipeTypeOptions="{{recipeTypeOptions}}"
  bind:close="hideForm"
  bind:filterTypeChange="handleFilterTypeChange"
  bind:recipeChange="handleRecipeChange"
  bind:dietDescInput="handleDietDescInput"
  bind:submit="handleSubmit"
  bind:cancel="hideForm"
></diet-form-modal>
